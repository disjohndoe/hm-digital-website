---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import MedicalPricingTable from '../components/medical/MedicalPricingTable.astro';
import { getTranslations } from '../i18n/ui';

const locale = 'hr';
const t = getTranslations(locale);
const m = t.medicalLanding;
---

<Layout
  title={m.meta.title}
  description={m.meta.description}
  canonical="/medicinski-softver"
  noindex={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "HM Digital Medicinski Softver",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Web",
      "description": m.hero.subtitle,
      "url": "https://hmdigital.hr/medicinski-softver",
      "inLanguage": "hr",
      "offers": [
        {
          "@type": "Offer",
          "name": m.pricing.solo.name,
          "price": "79",
          "priceCurrency": "EUR",
          "priceSpecification": { "@type": "UnitPriceSpecification", "unitText": "MONTH" },
          "description": m.pricing.solo.desc
        },
        {
          "@type": "Offer",
          "name": m.pricing.poliklinika.name,
          "price": "199",
          "priceCurrency": "EUR",
          "priceSpecification": { "@type": "UnitPriceSpecification", "unitText": "MONTH" },
          "description": m.pricing.poliklinika.desc
        }
      ],
      "provider": {
        "@type": "Organization",
        "name": "HM Digital",
        "url": "https://hmdigital.hr"
      },
      "featureList": [
        m.features.patients.title,
        m.features.scheduling.title,
        m.features.dentalChart.title,
        m.features.cezihModules.title,
        m.features.smartCard.title,
        m.features.cloudAccess.title
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": m.faq.items.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.a
        }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Naslovnica", "item": "https://hmdigital.hr/" },
        { "@type": "ListItem", "position": 2, "name": "Medicinski softver", "item": "https://hmdigital.hr/medicinski-softver" }
      ]
    })} />
  </Fragment>

  <!-- 1. Urgency Bar -->
  <div id="urgency-bar" class="bg-red-600 text-white text-sm text-center py-2 font-medium">
    <div class="container-custom">
      <span id="urgency-text"></span>
    </div>
  </div>

  <script is:inline>
    (function() {
      var deadline = new Date('2026-05-01T00:00:00+02:00');
      var now = new Date();
      var diff = deadline.getTime() - now.getTime();
      var days = Math.ceil(diff / (1000 * 60 * 60 * 24));
      var el = document.getElementById('urgency-text');
      if (!el) return;
      if (days > 0) {
        el.textContent = 'Zakon NN 14/2019, čl. 28 — do obaveznog CEZIH-a ostalo: ' + days + ' dana · Kazne do €13.200';
      } else {
        el.textContent = 'CEZIH je sada obavezan — kazne do €13.200 po prekršaju (čl. 35-37)';
      }
    })();
  </script>

  <!-- 2. Hero -->
  <section class="py-20 lg:py-32 bg-gradient-to-br from-slate-900 to-primary-900">
    <div class="container-custom text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 max-w-4xl mx-auto">
        {m.hero.title}
      </h1>
      <p class="text-lg sm:text-xl leading-relaxed text-slate-300 max-w-3xl mx-auto mb-10">
        {m.hero.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button href="#usporedba" variant="primary" size="lg">
          {m.hero.ctaCompare}
        </Button>
        <Button href="#mogucnosti" variant="outline" size="lg" class="!border-white !text-white hover:!bg-white/10">
          {m.hero.ctaFeatures}
        </Button>
      </div>
    </div>
  </section>

  <!-- 3. Problem Statement -->
  <section class="py-16 lg:py-24 bg-white" id="mogucnosti">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {m.problem.title}
        </h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          {m.problem.subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <Card padding="lg">
          <div class="w-10 h-10 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.problem.deadline.title}</h3>
          <p class="text-slate-600 text-sm">{m.problem.deadline.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-amber-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.problem.legacy.title}</h3>
          <p class="text-slate-600 text-sm">{m.problem.legacy.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.problem.cloudNoCezih.title}</h3>
          <p class="text-slate-600 text-sm">{m.problem.cloudNoCezih.desc}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- 4. Solution Overview -->
  <section class="py-16 lg:py-24 bg-gradient-to-br from-primary-50 to-white">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {m.solution.title}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <Card padding="lg" class="text-center">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.solution.cloudUx.title}</h3>
          <p class="text-slate-600 text-sm">{m.solution.cloudUx.desc}</p>
        </Card>
        <Card padding="lg" class="text-center">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.solution.cezihG9.title}</h3>
          <p class="text-slate-600 text-sm">{m.solution.cezihG9.desc}</p>
        </Card>
        <Card padding="lg" class="text-center">
          <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.solution.dental.title}</h3>
          <p class="text-slate-600 text-sm">{m.solution.dental.desc}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- 5. Comparison Table -->
  <section class="py-16 lg:py-24 bg-white" id="usporedba">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {m.comparison.title}
        </h2>
      </div>
      <div class="max-w-4xl mx-auto overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b-2 border-slate-200">
              <th class="py-4 px-4 text-sm font-semibold text-slate-500">{m.comparison.headers.feature}</th>
              <th class="py-4 px-4 text-sm font-semibold text-slate-500 text-center">{m.comparison.headers.legacy}</th>
              <th class="py-4 px-4 text-sm font-semibold text-slate-500 text-center">{m.comparison.headers.cloudAlt}</th>
              <th class="py-4 px-4 text-sm font-semibold text-primary-600 text-center">{m.comparison.headers.hmDigital}</th>
            </tr>
          </thead>
          <tbody>
            {Object.entries(m.comparison.rows).map(([key, label]) => (
              <tr class="border-b border-slate-100">
                <td class="py-3 px-4 text-sm text-slate-700 font-medium">{label}</td>
                <td class="py-3 px-4 text-center">
                  {typeof m.comparison.legacy[key] === 'boolean' ? (
                    m.comparison.legacy[key] ? (
                      <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    ) : (
                      <svg class="w-5 h-5 text-red-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    )
                  ) : (
                    <span class="text-sm text-slate-600">{m.comparison.legacy[key]}</span>
                  )}
                </td>
                <td class="py-3 px-4 text-center">
                  {typeof m.comparison.cloudAlt[key] === 'boolean' ? (
                    m.comparison.cloudAlt[key] ? (
                      <svg class="w-5 h-5 text-green-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    ) : (
                      <svg class="w-5 h-5 text-red-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    )
                  ) : (
                    <span class="text-sm text-slate-600">{m.comparison.cloudAlt[key]}</span>
                  )}
                </td>
                <td class="py-3 px-4 text-center bg-primary-50/50">
                  {typeof m.comparison.hmDigital[key] === 'boolean' ? (
                    m.comparison.hmDigital[key] ? (
                      <svg class="w-5 h-5 text-primary-600 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    ) : (
                      <svg class="w-5 h-5 text-red-400 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    )
                  ) : (
                    <span class="text-sm font-semibold text-primary-600">{m.comparison.hmDigital[key]}</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 6. Features Grid -->
  <section class="py-16 lg:py-24 bg-slate-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {m.features.title}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.patients.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.patients.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.scheduling.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.scheduling.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.dentalChart.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.dentalChart.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.cezihModules.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.cezihModules.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.smartCard.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.smartCard.desc}</p>
        </Card>
        <Card padding="lg">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
          </div>
          <h3 class="text-lg font-semibold text-slate-900 mb-2">{m.features.cloudAccess.title}</h3>
          <p class="text-slate-600 text-sm">{m.features.cloudAccess.desc}</p>
        </Card>
      </div>
    </div>
  </section>

  <!-- 6. Pricing Table -->
  <MedicalPricingTable t={t} />

  <!-- 7. FAQ -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {m.faq.title}
        </h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-3">
        {m.faq.items.map((item) => (
          <details class="group border border-slate-200 rounded-lg">
            <summary class="flex items-center justify-between cursor-pointer p-4 sm:p-5 font-medium text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
              {item.q}
              <svg class="w-5 h-5 text-slate-400 shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-4 sm:px-5 pb-4 sm:pb-5 text-slate-600 text-sm leading-relaxed">
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 10. CTA + Contact Form -->
  <section class="py-16 lg:py-24 bg-primary-600" id="demo-form">
    <div class="container-custom">
      <div class="text-center mb-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          {m.cta.title}
        </h2>
        <p class="text-lg text-primary-100 max-w-2xl mx-auto">
          {m.cta.subtitle}
        </p>
      </div>
      <div class="max-w-lg mx-auto">
        <form
          action="https://formspree.io/f/mgokrggg"
          method="POST"
          class="bg-white rounded-xl shadow-lg p-6 lg:p-8"
          data-form-security
        >
          <!-- Honeypot -->
          <div style="position: absolute; left: -5000px;" aria-hidden="true">
            <label for="_honey_med">Do not fill:</label>
            <input type="text" id="_honey_med" name="_honey" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" name="_form_timestamp" value="" />
          <input type="hidden" name="_subject" value="Medical MVP - Demo zahtjev" />
          <input type="hidden" name="_source" value="medicinski-softver" />

          <div class="space-y-6">
            <div>
              <label for="med-name" class="block text-sm font-medium text-slate-700 mb-2">
                {t.contact.form.name}
              </label>
              <input
                type="text"
                id="med-name"
                name="name"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors placeholder:text-slate-400"
                placeholder={t.contact.form.namePlaceholder}
              />
            </div>
            <div>
              <label for="med-email" class="block text-sm font-medium text-slate-700 mb-2">
                {t.contact.form.email}
              </label>
              <input
                type="email"
                id="med-email"
                name="email"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors placeholder:text-slate-400"
                placeholder={t.contact.form.emailPlaceholder}
              />
            </div>
            <div>
              <label for="med-message" class="block text-sm font-medium text-slate-700 mb-2">
                {t.contact.form.message}
              </label>
              <textarea
                id="med-message"
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors resize-none placeholder:text-slate-400"
                placeholder={t.contact.form.placeholder}
              ></textarea>
            </div>
            <Button type="submit" variant="primary" size="lg" class="w-full">
              {m.cta.form.submit}
            </Button>
          </div>
        </form>

        <div class="mt-8 text-center">
          <p class="text-primary-100 mb-2">{m.cta.directContact}</p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href={`mailto:${m.cta.email}`} class="text-white font-semibold hover:text-primary-200 transition-colors">
              {m.cta.email}
            </a>
            <a href={`tel:${m.cta.phone.replace(/\s/g, '')}`} class="text-white font-semibold hover:text-primary-200 transition-colors">
              {m.cta.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline src="/js/form-security.js"></script>
</Layout>
