---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero.astro';
import ValueProp from '../components/sections/ValueProp.astro';
import ServicesOverview from '../components/sections/ServicesOverview.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import Button from '../components/ui/Button.astro';
import { getTranslations, getLocaleFromPath, getPathForLocale } from '../i18n/ui';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const t = getTranslations(locale);
---

<Layout
  title="HM Digital - Softverski razvoj Hrvatska | Web aplikacije, ERP, Webshopovi, Automatizacija i Digitalizacija"
  description="Profesionalni softverski razvoj za hrvatsko tržište. Izrađujemo web aplikacije, webshopove, ERP sustave, Fiskalizaciju 2.0 i automatizaciju. 10+ godina iskustva. Zatražite ponudu!"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "url": "https://hmdigital.hr/",
    "name": "HM Digital",
    "description": "Profesionalni softverski razvoj za hrvatsko tržište - web aplikacije, webshopovi, ERP sustavi, automatizacija i digitalizacija dokumenata",
    "publisher": {
      "@type": "Organization",
      "name": "HM Digital",
      "url": "https://hmdigital.hr",
      "logo": "https://hmdigital.hr/logo.svg"
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://hmdigital.hr/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  })} />
  <Hero />

  <!-- Value Proposition -->
  <ValueProp />

  <!-- Services Preview -->
  <ServicesOverview />

  <!-- Secondary Offer: Document Digitization -->
  <section class="py-12 lg:py-16 bg-gradient-to-r from-amber-50 to-orange-50 border-y border-amber-200">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center">
        <h3 class="text-xl sm:text-2xl font-semibold text-slate-900 mb-3">
          {t.secondaryOffer.title}
        </h3>
        <p class="text-slate-600 mb-6">
          {t.secondaryOffer.desc}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href={getPathForLocale('/kontakt', locale)} variant="primary" size="md">
            {t.secondaryOffer.cta}
          </Button>
          <Button href={getPathForLocale('/cjenik', locale)} variant="outline" size="md">
            {t.secondaryOffer.cta2}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="py-16 lg:py-24 bg-slate-50">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          {t.projects.featuredTitle}
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          {t.projects.featuredSubtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- CEZIH Medical Software -->
        <div class="bg-white rounded-xl shadow-sm border border-primary-200 p-8 h-full flex flex-col hover:shadow-md hover:-translate-y-0.5 transition-all">
          <div class="flex-1">
            <span class="inline-block px-3 py-1 bg-primary-100 text-primary-700 text-xs font-semibold rounded-full mb-3">CEZIH · Cloud · Zdravstvo</span>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">CEZIH softver za ordinacije i poliklinike</h3>
            <p class="text-slate-600 mb-4">Medicinski softver s CEZIH integracijom — e-Nalaz, e-Recept, e-Uputnica iz clouda. Za privatne ordinacije i poliklinike.</p>
          </div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Cloud</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">CEZIH</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">React</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">TypeScript</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">PostgreSQL</span>
          </div>
          <Button href={getPathForLocale('/medicinski-softver', locale)} variant="outline" size="sm" class="w-full sm:w-auto">
            {t.projects.learnMore}
          </Button>
        </div>

        <ProjectCard
          title={t.projects.digitalniUred.title}
          description={t.projects.digitalniUred.description}
          tech={t.projects.digitalniUred.tech.split(', ')}
          href={getPathForLocale('/projekti', locale)}
          locale={locale}
        />

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 flex flex-col justify-center items-center text-center">
          <h3 class="text-xl font-semibold text-slate-900 mb-3">
            {t.projects.moreProjects}
          </h3>
          <p class="text-slate-600 mb-6">
            {t.projects.moreProjectsDesc}
          </p>
          <a
            href="https://softwarebymatt.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 border-2 border-primary-600 text-primary-600 hover:bg-primary-50 focus:ring-primary-500 hover:-translate-y-0.5 px-4 py-2 text-sm w-full sm:w-auto"
          >
            {t.projects.learnMore}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24 bg-primary-600">
    <div class="container-custom text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {t.projects.cta.title}
      </h2>
      <p class="text-lg text-primary-100 max-w-2xl mx-auto mb-8">
        {t.projects.cta.description}
      </p>
      <Button href={getPathForLocale('/kontakt', locale)} variant="secondary" size="lg">
        {t.projects.cta.button}
      </Button>
    </div>
  </section>
</Layout>
