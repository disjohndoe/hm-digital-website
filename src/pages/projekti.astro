---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import Button from '../components/ui/Button.astro';
import { getTranslations } from '../i18n/ui';

const locale = 'hr';
const t = getTranslations(locale);
---

<Layout
  title="Projekti - HM Digital | Naše reference i uspješni projekti"
  description="Pogledajte naše realizirane projekte: Digitalni ured, web aplikacije, webshopovi i ERP sustavi. Primjeri uspješnih implementacija za hrvatsko tržište."
  canonical="/projekti"
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-50 to-white pt-16 lg:pt-24 pb-0">
    <div class="container-custom">
      <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 mb-6">
        {t.projects.title}
      </h1>
      <p class="text-xl text-slate-600 max-w-3xl">
        {t.projects.subtitle}
      </p>
    </div>
  </section>

  <!-- Projects -->
  <section class="py-16 lg:py-24">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- CEZIH Medical Software -->
        <div class="bg-white rounded-xl shadow-sm border border-primary-200 p-8 h-full flex flex-col hover:shadow-md hover:-translate-y-0.5 transition-all">
          <div class="flex-1">
            <span class="inline-block px-3 py-1 bg-primary-100 text-primary-700 text-xs font-semibold rounded-full mb-3">CEZIH · Cloud · Zdravstvo</span>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">CEZIH softver za ordinacije i poliklinike</h3>
            <p class="text-slate-600 mb-4">Medicinski softver s CEZIH integracijom — e-Nalaz, e-Recept, e-Uputnica iz clouda. Za privatne ordinacije i poliklinike.</p>
          </div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Cloud</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">CEZIH</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">React</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">TypeScript</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">PostgreSQL</span>
          </div>
          <Button href="/medicinski-softver" variant="outline" size="sm" class="w-full sm:w-auto">
            {t.projects.learnMore}
          </Button>
        </div>

        <!-- Digitalni Ured -->
        <ProjectCard
          title="Digitalni ured"
          description="Platforma za digitalizaciju poslovnih procesa. Sustav omogućuje tvrtkama jednostavno upravljanje dokumentacijom, elektroničko potpisivanje i integraciju s postojećim poslovnim sustavima. Fokus na sigurnosti, pouzdanosti i jednostavnosti korištenja."
          tech={['Python', 'FastAPI', 'PostgreSQL', 'Next.js', 'Tailwind.css', 'Whisper (OpenAI)', 'Docker', 'Redis']}
          href="/demo/digitalni-ured"
          locale="hr"
        />

        <!-- External Link -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8 flex flex-col h-full">
          <div class="flex-1">
            <h3 class="text-xl font-semibold text-slate-900 mb-1.5 flex items-center gap-2">
              Još projekata
              <svg class="w-5 h-5 text-slate-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </h3>
            <p class="text-slate-600 mb-4">
              Pogledajte naše druge projekte na softwarebymatt.com. Baza naših drugih projekata.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">HTML/CSS</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">JavaScript</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">React.js</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Redux</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Node.js</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Python</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">WordPress</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">Bootstrap</span>
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm rounded-full">REST APIs</span>
          </div>
          <a
            href="https://softwarebymatt.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center font-medium rounded-lg transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 border-2 border-primary-600 text-primary-600 hover:bg-primary-50 focus:ring-primary-500 hover:-translate-y-0.5 px-4 py-2 text-sm w-full sm:w-auto"
          >
            {t.projects.learnMore}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-24 bg-slate-50">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-bold text-slate-900 mb-4">
        Imate ideju za projekt?
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
        Kontaktirajte nas i zajednički realizirajmo vašu viziju.
      </p>
      <a
        href="/kontakt"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-primary-600 rounded-lg hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500"
      >
        Započni projekt
      </a>
    </div>
  </section>
</Layout>
