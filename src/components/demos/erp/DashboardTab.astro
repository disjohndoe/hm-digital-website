---
import DemoKpiCard from '../DemoKpiCard.astro';
import type { Translations } from '../../../i18n/ui';
import { kpiTrends, activityFeed, orderStatusBreakdown } from '../../../data/demo-erp';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const d = t.demoErp.dashboard;

const activityColors: Record<string, string> = {
  production: 'bg-green-500',
  orders: 'bg-blue-500',
  inventory: 'bg-amber-500',
  quality: 'bg-purple-500',
  system: 'bg-slate-400',
};

const activityMessages = [d.activities.a1, d.activities.a2, d.activities.a3, d.activities.a4, d.activities.a5];
---

<div class="demo-tab-panel" data-panel="dashboard">
  <!-- KPIs -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
    <DemoKpiCard label={d.kpi1.label} value={d.kpi1.value} icon="box" color="primary" trend="up" trendValue="+14.6%" trendData={kpiTrends.produced} />
    <DemoKpiCard label={d.kpi2.label} value={d.kpi2.value} icon="gear" color="green" trend="up" trendValue="+6.1%" trendData={kpiTrends.capacity} />
    <DemoKpiCard label={d.kpi3.label} value={d.kpi3.value} icon="clipboard" color="amber" trend="down" trendValue="-17.9%" trendData={kpiTrends.openOrders} />
    <DemoKpiCard label={d.kpi4.label} value={d.kpi4.value} icon="check" color="green" trend="up" trendValue="+1.3%" trendData={kpiTrends.quality} />
    <DemoKpiCard label={d.kpi5.label} value={d.kpi5.value} icon="truck" color="primary" trend="up" trendValue="+4.4%" trendData={kpiTrends.onTime} />
    <DemoKpiCard label={d.kpi6.label} value={d.kpi6.value} icon="alert" color="red" trend="down" trendValue="-42.9%" trendData={kpiTrends.downtime} />
  </div>

  <!-- Charts -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 border-t-4 border-t-primary-500 p-6">
      <h3 class="text-lg font-semibold text-slate-900 mb-4">{d.chartProductionByDay}</h3>
      <div class="relative h-64">
        <canvas id="erp-chart-production"></canvas>
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 border-t-4 border-t-green-500 p-6">
      <h3 class="text-lg font-semibold text-slate-900 mb-4">{d.chartEfficiency}</h3>
      <div class="relative h-64">
        <canvas id="erp-chart-efficiency"></canvas>
      </div>
    </div>
  </div>

  <!-- Activity Feed + Order Status Donut -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h3 class="text-lg font-semibold text-slate-900 mb-4">{d.activityTitle}</h3>
      <div class="space-y-4">
        {activityFeed.map((entry, i) => (
          <div class="flex items-start gap-3">
            <div class={`w-2.5 h-2.5 rounded-full mt-1.5 shrink-0 ${activityColors[entry.type]}`}></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-slate-700">{activityMessages[i]}</p>
              <p class="text-xs text-slate-400 mt-0.5">{entry.time}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h3 class="text-lg font-semibold text-slate-900 mb-4">{d.orderStatusTitle}</h3>
      <div class="relative h-56">
        <canvas id="erp-chart-donut"></canvas>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ days: d.days, orderStatus: orderStatusBreakdown, donutLabels: `${t.demoErp.workOrders.columns.pending},${t.demoErp.workOrders.columns.inProgress},${t.demoErp.workOrders.columns.completed}` }}>
  window.__erpChartLabels = { days: days.split(',') };
  window.__erpOrderStatus = orderStatus;
  window.__erpDonutLabels = donutLabels.split(',');
</script>

<script>
  import { Chart, registerables } from 'chart.js';
  Chart.register(...registerables);

  let chartsInitialized = false;

  function initErpCharts() {
    if (chartsInitialized) return;
    const canvas1 = document.getElementById('erp-chart-production') as HTMLCanvasElement;
    const canvas2 = document.getElementById('erp-chart-efficiency') as HTMLCanvasElement;
    const canvas3 = document.getElementById('erp-chart-donut') as HTMLCanvasElement;
    if (!canvas1 || !canvas2 || canvas1.offsetParent === null) return;

    chartsInitialized = true;
    const labels = (window as any).__erpChartLabels;
    const productionByDay = [185, 210, 198, 220, 195, 142, 134];
    const efficiencyTrend = [82, 84, 83, 87, 86, 89, 87];

    // Production chart with gradient fill
    const ctx1 = canvas1.getContext('2d')!;
    const gradient1 = ctx1.createLinearGradient(0, 0, 0, 256);
    gradient1.addColorStop(0, 'rgba(37, 99, 235, 0.8)');
    gradient1.addColorStop(1, 'rgba(37, 99, 235, 0.4)');

    new Chart(canvas1, {
      type: 'bar',
      data: {
        labels: labels.days,
        datasets: [{
          label: '',
          data: productionByDay,
          backgroundColor: gradient1,
          borderRadius: 8,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#f8fafc',
            bodyColor: '#f8fafc',
            padding: 12,
            cornerRadius: 8,
            displayColors: false,
          }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { color: '#94a3b8' } },
          x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
        }
      }
    });

    // Efficiency chart with gradient fill
    const ctx2 = canvas2.getContext('2d')!;
    const gradient2 = ctx2.createLinearGradient(0, 0, 0, 256);
    gradient2.addColorStop(0, 'rgba(5, 150, 105, 0.2)');
    gradient2.addColorStop(1, 'rgba(5, 150, 105, 0.02)');

    new Chart(canvas2, {
      type: 'line',
      data: {
        labels: labels.days,
        datasets: [{
          label: '',
          data: efficiencyTrend,
          borderColor: '#059669',
          backgroundColor: gradient2,
          fill: true,
          tension: 0.4,
          borderWidth: 3,
          pointRadius: 5,
          pointBackgroundColor: '#059669',
          pointBorderColor: '#ffffff',
          pointBorderWidth: 2,
          pointHoverRadius: 7,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#f8fafc',
            bodyColor: '#f8fafc',
            padding: 12,
            cornerRadius: 8,
            displayColors: false,
          }
        },
        scales: {
          y: { min: 70, max: 100, grid: { color: '#f1f5f9' }, ticks: { color: '#94a3b8' } },
          x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
        }
      }
    });

    // Order status donut chart
    if (canvas3) {
      const orderStatus = (window as any).__erpOrderStatus;
      const donutLabels = (window as any).__erpDonutLabels;
      new Chart(canvas3, {
        type: 'doughnut',
        data: {
          labels: donutLabels,
          datasets: [{
            data: [orderStatus.pending, orderStatus.inProgress, orderStatus.completed],
            backgroundColor: ['#f59e0b', '#3b82f6', '#10b981'],
            borderWidth: 0,
            borderRadius: 4,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '65%',
          plugins: {
            legend: {
              position: 'bottom',
              labels: { padding: 16, usePointStyle: true, pointStyle: 'circle', color: '#475569' }
            },
            tooltip: {
              backgroundColor: '#1e293b',
              titleColor: '#f8fafc',
              bodyColor: '#f8fafc',
              padding: 12,
              cornerRadius: 8,
            }
          }
        }
      });
    }
  }

  requestAnimationFrame(initErpCharts);
  document.addEventListener('tab-visible', () => requestAnimationFrame(initErpCharts));
</script>
