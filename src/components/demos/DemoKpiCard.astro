---
interface Props {
  label: string;
  value: string;
  icon?: string;
  trend?: 'up' | 'down' | 'neutral';
  trendValue?: string;
  trendData?: number[];
  color?: 'primary' | 'green' | 'amber' | 'red';
}

const { label, value, icon = 'chart', trend, trendValue, trendData, color = 'primary' } = Astro.props;

const icons: Record<string, string> = {
  chart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
  users: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  clock: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />',
  box: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />',
  gear: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />',
  clipboard: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />',
  check: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
  truck: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0" />',
  alert: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />',
};

const svgPath = icons[icon] || icons.chart;

const colorMap: Record<string, { bg: string; icon: string; sparkline: string }> = {
  primary: { bg: 'bg-primary-100', icon: 'text-primary-600', sparkline: '#2563eb' },
  green: { bg: 'bg-green-100', icon: 'text-green-600', sparkline: '#059669' },
  amber: { bg: 'bg-amber-100', icon: 'text-amber-600', sparkline: '#d97706' },
  red: { bg: 'bg-red-100', icon: 'text-red-600', sparkline: '#dc2626' },
};

const c = colorMap[color] || colorMap.primary;

// Generate sparkline SVG path from trendData
let sparklinePath = '';
if (trendData && trendData.length > 1) {
  const width = 80;
  const height = 24;
  const padding = 2;
  const min = Math.min(...trendData);
  const max = Math.max(...trendData);
  const range = max - min || 1;
  const points = trendData.map((val, i) => {
    const x = padding + (i / (trendData.length - 1)) * (width - padding * 2);
    const y = padding + (1 - (val - min) / range) * (height - padding * 2);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  });
  sparklinePath = points.join(' ');
}
---

<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <p class="text-sm text-slate-500 mb-1">{label}</p>
      <div class="flex items-baseline gap-2">
        <p class="text-2xl font-bold text-slate-900">{value}</p>
        {trend && trendValue && (
          <span class:list={[
            'inline-flex items-center gap-0.5 text-xs font-semibold px-1.5 py-0.5 rounded-full',
            trend === 'up' ? 'text-green-700 bg-green-50' : trend === 'down' ? 'text-red-700 bg-red-50' : 'text-slate-500 bg-slate-50'
          ]}>
            {trend === 'up' && (
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
              </svg>
            )}
            {trend === 'down' && (
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
              </svg>
            )}
            {trendValue}
          </span>
        )}
      </div>
    </div>
    <div class={`w-10 h-10 ${c.bg} rounded-lg flex items-center justify-center shrink-0`}>
      <svg class={`w-5 h-5 ${c.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <Fragment set:html={svgPath} />
      </svg>
    </div>
  </div>
  {sparklinePath && (
    <div class="mt-3">
      <svg viewBox="0 0 80 24" class="w-full h-6" preserveAspectRatio="none">
        <polyline
          fill="none"
          stroke={c.sparkline}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          points={sparklinePath}
        />
      </svg>
    </div>
  )}
</div>
