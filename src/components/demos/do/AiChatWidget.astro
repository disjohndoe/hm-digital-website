---
import type { Translations } from '../../../i18n/ui';
import { chatMessages, cannedResponses } from '../../../data/demo-digital-office';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const o = t.demoDigitalOffice.aiOcr;
---

<div class="bg-white rounded-xl shadow-sm border border-slate-200 flex flex-col h-full">
  <!-- Header -->
  <div class="flex items-center justify-between p-4 border-b border-slate-200">
    <h3 class="text-lg font-semibold text-slate-900">{o.chatTitle}</h3>
    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 text-xs font-medium rounded-full bg-primary-100 text-primary-700">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      {o.chatPoweredBy}
    </span>
  </div>

  <!-- Messages -->
  <div class="flex-1 overflow-y-auto p-4 space-y-4" id="ai-chat-messages">
    {chatMessages.map(msg => {
      const content = (o.chatMessages as any)[msg.contentKey] as string;
      return msg.role === 'user' ? (
        <div class="flex justify-end">
          <div class="max-w-[80%] bg-primary-600 text-white rounded-2xl rounded-br-md px-4 py-3 text-sm">
            {content}
          </div>
        </div>
      ) : (
        <div class="flex justify-start">
          <div class="max-w-[80%] bg-slate-100 text-slate-800 rounded-2xl rounded-bl-md px-4 py-3 text-sm">
            {content}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Typing indicator (hidden by default) -->
  <div id="ai-chat-typing" class="hidden px-4 pb-2">
    <div class="inline-flex items-center gap-2 bg-slate-100 rounded-2xl rounded-bl-md px-4 py-3 text-sm text-slate-500">
      <span class="flex gap-1">
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
        <span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
      </span>
      {o.chatTyping}
    </div>
  </div>

  <!-- Input -->
  <div class="p-4 border-t border-slate-200">
    <div class="flex gap-2">
      <input
        type="text"
        id="ai-chat-input"
        placeholder={o.chatPlaceholder}
        class="flex-1 px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-primary-400 focus:ring-1 focus:ring-primary-400"
      />
      <button
        type="button"
        id="ai-chat-send"
        class="px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium hover:bg-primary-700 transition-colors shrink-0"
      >
        {o.chatSend}
      </button>
    </div>
  </div>
</div>

<script define:vars={{ cannedData: JSON.stringify(cannedResponses.map(k => (o.chatCanned as any)[k] as string)) }}>
  window.__aiChatCanned = JSON.parse(cannedData);
</script>

<script>
  function initAiChat() {
    const input = document.getElementById('ai-chat-input') as HTMLInputElement | null;
    const sendBtn = document.getElementById('ai-chat-send');
    const messagesContainer = document.getElementById('ai-chat-messages');
    const typingIndicator = document.getElementById('ai-chat-typing');
    if (!input || !sendBtn || !messagesContainer) return;

    const cannedResponses: string[] = (window as any).__aiChatCanned || [];
    let cannedIndex = 0;

    function addMessage(text: string, role: 'user' | 'assistant') {
      const wrapper = document.createElement('div');
      wrapper.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[80%] bg-primary-600 text-white rounded-2xl rounded-br-md px-4 py-3 text-sm'
        : 'max-w-[80%] bg-slate-100 text-slate-800 rounded-2xl rounded-bl-md px-4 py-3 text-sm';
      bubble.textContent = text;
      wrapper.appendChild(bubble);
      messagesContainer.appendChild(wrapper);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function handleSend() {
      const text = input.value.trim();
      if (!text) return;

      addMessage(text, 'user');
      input.value = '';

      // Show typing
      if (typingIndicator) typingIndicator.classList.remove('hidden');
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      setTimeout(() => {
        if (typingIndicator) typingIndicator.classList.add('hidden');
        const response = cannedResponses[cannedIndex % cannedResponses.length] || 'OK';
        cannedIndex++;
        addMessage(response, 'assistant');
      }, 1500);
    }

    sendBtn.addEventListener('click', handleSend);
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') handleSend();
    });
  }

  initAiChat();
  document.addEventListener('astro:after-swap', initAiChat);
</script>
