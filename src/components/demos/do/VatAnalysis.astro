---
import type { Translations } from '../../../i18n/ui';
import { vatRows } from '../../../data/demo-digital-office';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const a = t.demoDigitalOffice.accounting;

const formatEur = (n: number) => n.toLocaleString('de-DE') + ' EUR';
const totals = vatRows.reduce((acc, r) => ({ base: acc.base + r.base, vat: acc.vat + r.vat, total: acc.total + r.total }), { base: 0, vat: 0, total: 0 });
---

<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-lg font-semibold text-slate-900">{a.vatTitle}</h3>
    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-700">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      {a.finaCompliant}
    </span>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200">
          <th class="text-left py-3 px-2 font-medium text-slate-500">{a.vatColumns.rate}</th>
          <th class="text-right py-3 px-2 font-medium text-slate-500">{a.vatColumns.base}</th>
          <th class="text-right py-3 px-2 font-medium text-slate-500">{a.vatColumns.vat}</th>
          <th class="text-right py-3 px-2 font-medium text-slate-500">{a.vatColumns.total}</th>
        </tr>
      </thead>
      <tbody>
        {vatRows.map(row => (
          <tr class="border-b border-slate-100 hover:bg-slate-50">
            <td class="py-3 px-2 font-medium text-slate-900">{row.rate}</td>
            <td class="py-3 px-2 text-right text-slate-700">{formatEur(row.base)}</td>
            <td class="py-3 px-2 text-right text-slate-700">{formatEur(row.vat)}</td>
            <td class="py-3 px-2 text-right font-medium text-slate-900">{formatEur(row.total)}</td>
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr class="border-t-2 border-slate-300">
          <td class="py-3 px-2 font-bold text-slate-900">{a.vatTotal}</td>
          <td class="py-3 px-2 text-right font-bold text-slate-900">{formatEur(totals.base)}</td>
          <td class="py-3 px-2 text-right font-bold text-slate-900">{formatEur(totals.vat)}</td>
          <td class="py-3 px-2 text-right font-bold text-slate-900">{formatEur(totals.total)}</td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="mt-4">
    <button
      type="button"
      class="quick-action-btn inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium hover:bg-primary-700 transition-colors"
      data-toast={a.generateVat}
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
      {a.generateVat}
    </button>
  </div>
</div>
