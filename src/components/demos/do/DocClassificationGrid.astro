---
import type { Translations } from '../../../i18n/ui';
import { docClassifications } from '../../../data/demo-digital-office';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const o = t.demoDigitalOffice.aiOcr;

const iconPaths: Record<string, string> = {
  receipt: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />',
  document: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
  tag: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />',
  cart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />',
  mail: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />',
};

const accuracyColor = (a: number) => {
  if (a >= 98) return 'text-green-600';
  if (a >= 97) return 'text-blue-600';
  return 'text-amber-600';
};
---

<div>
  <h3 class="text-lg font-semibold text-slate-900 mb-4">{o.classificationTitle}</h3>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
    {docClassifications.map(doc => {
      const typeLabel = (o.classificationTypes as any)[doc.typeKey] as string;
      return (
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 text-center hover:shadow-lg hover:scale-[1.02] transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 rounded-lg flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={iconPaths[doc.icon] || iconPaths.document} />
            </svg>
          </div>
          <p class="text-sm font-medium text-slate-900 mb-1">{typeLabel}</p>
          <p class:list={['text-lg font-bold', accuracyColor(doc.accuracy)]}>
            {doc.accuracy}%
          </p>
          <p class="text-xs text-slate-400">{o.classificationAccuracy}</p>
        </div>
      );
    })}
  </div>
</div>
