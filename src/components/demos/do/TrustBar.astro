---
import type { Translations } from '../../../i18n/ui';
import { trustStats } from '../../../data/demo-digital-office';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const a = t.demoDigitalOffice.automation;

const stats = [
  { value: trustStats.users, label: a.trustUsers },
  { value: trustStats.docs, label: a.trustDocs },
  { value: trustStats.uptime, label: a.trustUptime },
  { value: trustStats.accuracy, label: a.trustAccuracy },
];
---

<div class="bg-gradient-to-r from-primary-50 to-primary-100 rounded-2xl p-8">
  <h3 class="text-lg font-semibold text-slate-900 text-center mb-6">{a.trustTitle}</h3>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
    {stats.map(stat => (
      <div class="text-center">
        <p class="text-3xl font-bold text-primary-700">{stat.value}</p>
        <p class="text-sm text-slate-600 mt-1">{stat.label}</p>
      </div>
    ))}
  </div>
</div>
