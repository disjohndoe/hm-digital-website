---
// Shared demo toast component - shows a brief notification for demo actions
// Usage: dispatch CustomEvent 'demo-toast' with detail: { message: string }
---

<div
  id="demo-toast"
  class="fixed bottom-6 right-6 z-50 max-w-sm bg-slate-900 text-white px-5 py-3 rounded-lg shadow-xl transform translate-y-20 opacity-0 transition-all duration-300 pointer-events-none"
  role="alert"
>
  <div class="flex items-center gap-3">
    <svg class="w-5 h-5 text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span id="demo-toast-text" class="text-sm"></span>
  </div>
</div>

<script>
  function initDemoToast() {
    const toast = document.getElementById('demo-toast');
    const toastText = document.getElementById('demo-toast-text');
    if (!toast || !toastText) return;

    let hideTimeout: number | undefined;

    document.addEventListener('demo-toast', ((e: CustomEvent) => {
      if (hideTimeout) clearTimeout(hideTimeout);
      toastText.textContent = e.detail?.message || '';
      toast.classList.remove('translate-y-20', 'opacity-0', 'pointer-events-none');
      toast.classList.add('translate-y-0', 'opacity-100');

      hideTimeout = window.setTimeout(() => {
        toast.classList.add('translate-y-20', 'opacity-0', 'pointer-events-none');
        toast.classList.remove('translate-y-0', 'opacity-100');
      }, 3000);
    }) as EventListener);
  }

  initDemoToast();
  document.addEventListener('astro:after-swap', initDemoToast);
</script>
